{
  "name": "bizify",
  "version": "1.0.1",
  "description": "Lightweight React MVVM framework backed by zustand",
  "keywords": [
    "react",
    "mvvm",
    "viewmodel",
    "state",
    "zustand"
  ],
  "homepage": "https://github.com/hstarorg/bizify",
  "bugs": {
    "url": "https://github.com/hstarorg/bizify/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hstarorg/bizify.git"
  },
  "license": "MIT",
  "author": "hstarorg <hm910705@163.com>",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/types/react/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/react/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/types/core/index.d.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.cjs"
    }
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "pnpm clean && rolldown -c && tsc -p tsconfig.build.json",
    "dev": "vitest",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "lint:fix": "oxlint --fix src test",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:deploy": "gh-pages -d docs/.vitepress/dist",
    "prepare": "husky",
    "release": "pnpm build && pnpm publish"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.3.0",
    "oxlint": "^0.15.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rolldown": "^1.0.0-beta.1",
    "shiki": "^4.0.2",
    "typescript": "^5.7.2",
    "vitepress": "^1.5.0",
    "vitest": "^2.1.8"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxlint --fix"
    ]
  },
  "packageManager": "pnpm@9.0.0",
  "dependencies": {
    "valtio": "^2.3.1"
  }
}
